      --shadow:   0 6px 28px rgba(30,18,24,.09);
    }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      background: var(--light);
      color: var(--dark);
      line-height: 1.7;
    }

    /* ── LANG BAR ── */
    .lang-bar {
      position: sticky; top: 0; z-index: 200;
      background: rgba(253,245,248,.96);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(201,85,122,.13);
      display: flex; justify-content: center; gap: 8px;
      padding: 9px 0;
    }
    .lang-btn {
      font-family: 'Jost', sans-serif;
      font-size: .68rem; font-weight: 500;
      letter-spacing: .14em; text-transform: uppercase;
      padding: 5px 16px; border-radius: 999px;
      border: 1.5px solid var(--rose);
      background: transparent; color: var(--rose);
      cursor: pointer; transition: all .2s;
    }
    .lang-btn.active, .lang-btn:hover {
      background: var(--rose); color: var(--white);
    }

    /* ── LANGUAGE VISIBILITY ── */
    [data-lang]   { display: none; }
    .lang-de [data-lang="de"],
    .lang-en [data-lang="en"],
    .lang-tr [data-lang="tr"] { display: block; }
    .il-de, .il-en, .il-tr { display: none; }
    .lang-de .il-de,
    .lang-en .il-en,
    .lang-tr .il-tr { display: inline; }


    /* ── SUBPAGE HEADER ── */
    .sub-header {
